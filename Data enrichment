--1.  Cleaned null datas from dataset, there is 5 courses with course id and name but no other information, so we exclude the null data for preventing issues for next steps
  2.  Make new column by price_range, subscribers range, review range, duration range, lecture range for next level data visualization and exploration
  3.  Get make new column for published year and month 
4. Create view as udemy cleaned

CREATE VIEW udemy_report AS 

SELECT 
  course_id,
  course_title,
  is_paid,
  price, 
  CASE 
    WHEN price = 0 THEN 'Free'
    WHEN price >0 and price <=50 THEN '0-50usd'
    WHEN price >50 and price <=100 THEN '50-100usd'
    WHEN price >100 THEN '>100usd'
  END as price_range,
  num_subscribers,
  CASE 
    WHEN num_subscribers > 0 and num_subscribers <= 1000 THEN 'Low subs'
    WHEN num_subscribers > 1000 and num_subscribers <= 3000 THEN 'Medium subs'
    WHEN num_subscribers > 3000 and num_subscribers <= 5000 THEN 'High subs'
    WHEN num_subscribers > 5000 THEN 'Very High subs'
  END as subscribers_range,
num_reviews,
CASE 
  WHEN num_reviews >0 and num_reviews<=300 then 'Low engagement'
  WHEN num_reviews >300 and num_reviews<=600 then 'Medium engagement'
  WHEN num_reviews >600 and num_reviews<=900 then 'High engagement'
  ELSE 'Very high engagement'
  END as review_range,
num_lectures,
 Case 
       WHEN num_lectures >0 and num_lectures <=30 THEN '0-30'
       WHEN num_lectures >30 and num_lectures <=60 THEN '30-60'
       WHEN num_lectures >60 and num_lectures <=160 THEN '60-160'
       ELSE 'more than 160'
       END lectures_bin,
level,
content_duration,
 CASE
       WHEN content_duration <= 10 THEN '0-10'
       WHEN content_duration > 10 AND content_duration <= 25 THEN '10-25'
       WHEN content_duration > 20 AND content_duration <=35 THEN '25-35'
       WHEN content_duration > 30 AND content_duration <=45 THEN '35-45'
       else 'more than 45'
       end as duration_bin,
YEAR(published_timestamp) as year,
MONTH(published_timestamp) as month,
subject,
published_timestamp
FROM udemy_courses
where is_paid is not null
subject,
published_timestamp
