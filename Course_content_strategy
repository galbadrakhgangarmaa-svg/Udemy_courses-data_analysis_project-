-- COURSE & CONTENT STRATEGY
-- 1. Which course category and subject gets most subscribers?

SELECT 
  subject,
  SUM(num_subscribers)
FROM udemy_cleaned
GROUP BY subject

-- 2. Do courses with more lectures get more students

SELECT 
  lectures_bin,
  sum(num_subscribers) as subs,
  (SELECT sum(num_subscribers) FROM udemy_report) as total_subs,
  ROUND(sum(num_subscribers) * 100.0 / (SELECT sum(num_subscribers) FROM udemy_report),2) as lecture_subs
FROM udemy_report
GROUP BY lectures_bin

--3. Does course duration affect course popularity

SELECT 
  duration_bin,
  sum(num_subscribers) as subs,
  (SELECT sum(num_subscribers) FROM udemy_report) as total_subs,
  ROUND(sum(num_subscribers) * 100.0 / (SELECT sum(num_subscribers) FROM udemy_report),2) as lecture_subs
FROM udemy_report
GROUP BY duration_bin

